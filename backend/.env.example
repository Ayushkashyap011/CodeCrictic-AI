# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=codecritic

# ── Piston API ────────────────────────────────────────────────────────────────
# No API key needed! Piston is free and open — https://emkc.org/api/v2/piston
# PISTON_URL is hardcoded in piston.py, nothing to configure here.

# ── AI Engine (Part 2) ────────────────────────────────────────────────────────
# Groq AI — FREE at https://console.groq.com (no credit card needed!)
GROQ_API_KEY=gsk_your_key_here

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change_me_in_production
CORS_ORIGINS=http://localhost:3000
